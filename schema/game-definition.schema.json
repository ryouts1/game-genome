{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/game-genome/game-definition.schema.json",
  "title": "game-genome definition",
  "type": "object",
  "required": [
    "id",
    "name",
    "board",
    "players",
    "pieceKinds",
    "actionCatalog",
    "initialState",
    "termination"
  ],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "board": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "players": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "name", "forward"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "forward": { "enum": [1, -1] }
        }
      }
    },
    "turnOrder": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pieceKinds": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "shortLabel": { "type": "string" },
          "defaultSymbol": { "type": "string" },
          "symbolByPlayer": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "movement": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "vectors"],
              "properties": {
                "type": { "enum": ["step", "ray"] },
                "mode": { "enum": ["move", "capture", "move-or-capture"] },
                "orientation": { "enum": ["absolute", "forward"] },
                "maxDistance": { "type": "integer", "minimum": 1 },
                "vectors": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 2,
                    "items": { "type": "integer" }
                  }
                }
              }
            }
          },
          "evaluation": {
            "type": "object",
            "properties": {
              "value": { "type": "number" }
            }
          }
        }
      }
    },
    "actionCatalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "enum": ["place", "move-piece"] },
          "pieceKind": { "type": "string" },
          "pieceKinds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "enum": ["empty", "gravity", "row-zone", "column-zone", "cell-whitelist"]
                }
              }
            }
          },
          "inventory": {
            "type": "object",
            "properties": {
              "byPlayer": {
                "type": "object",
                "additionalProperties": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "initialState": {
      "type": "object",
      "required": ["pieces"],
      "properties": {
        "pieces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "owner", "x", "y"],
            "properties": {
              "kind": { "type": "string" },
              "owner": { "type": "string" },
              "x": { "type": "integer", "minimum": 0 },
              "y": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "termination": {
      "type": "object",
      "required": ["winConditions"],
      "properties": {
        "winConditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "enum": ["line", "capture-all", "reach-row", "opponent-has-no-legal-moves"]
              }
            }
          }
        },
        "drawConditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "enum": ["board-full", "move-limit", "no-legal-moves"] },
              "maxMoves": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "terminalScore": { "type": "number" },
        "weights": {
          "type": "object",
          "properties": {
            "material": { "type": "number" },
            "mobility": { "type": "number" },
            "centerControl": { "type": "number" },
            "advancement": { "type": "number" },
            "linePotential": { "type": "number" }
          }
        }
      }
    }
  }
}
